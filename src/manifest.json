{
  "manifest_version": 3,
  "name": "Ollama Sidebar",
  "version": "0.1.0",
  "description": "Chat with your local Ollama models from a browser sidepanel",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "commands",
    "windows"
  ],
  "action": {
    "default_title": "Open Ollama Sidebar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles/icon.css"]
    }
  ],
  "commands": {
    "extract-content": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Extract page content and send to Ollama Sidebar"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": ["<all_urls>"]
}
